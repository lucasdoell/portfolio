---
import Layout from "@layouts/Layout.astro";
import { GlobeIcon, MailIcon, PhoneIcon } from "lucide-react";
import { Section } from "@/components/react/ui/section";
import { Button } from "@/components/react/ui/button";
import { Card, CardHeader, CardContent } from "@/components/react/ui/card";
import { Badge } from "@/components/react/ui/badge";
import { ProjectCard } from "@/components/react/project-card";
import { GitHubIcon } from "@/components/icons/GithubIcon";
import { LinkedInIcon } from "@/components/icons/LinkedInIcon";
import { XIcon } from "@/components/icons/XIcon";
import "@/styles/globals.css";
---

<Layout title="Lucas Doell">
  <main
    class="container relative lg:mx-auto scroll-my-12 overflow-auto p-4 print:p-12 md:p-16"
  >
    <section
      class="mx-auto w-full max-w-2xl space-y-8 bg-white print:space-y-6"
    >
      <div class="flex items-center justify-between">
        <div class="flex-1 space-y-1.5">
          <h1 class="text-2xl font-bold">Lucas Doell</h1>
          <p
            class="max-w-md text-pretty font-mono text-sm text-muted-foreground"
          >
            I'm currently working for Appstle Inc. as a software developer. I'm
            also learning new technologies and working on side projects in my
            free time.
          </p>
          <p
            class="max-w-md items-center text-pretty font-mono text-xs text-muted-foreground"
          >
            <a
              class="inline-flex gap-x-1.5 align-baseline leading-none hover:underline"
              href="https://www.google.com/maps/place/Ithaca"
              target="_blank"
            >
              <GlobeIcon className="h-3 w-3" />
               Ithaca, NY
            </a>
          </p>
          <div
            class="flex gap-x-1 pt-1 font-mono text-sm text-muted-foreground print:hidden"
          >
            <a href={`mailto:lucas@lux.dev`}>
              <Button className="h-8 w-8" variant="outline" size="icon">
                <MailIcon className="h-4 w-4" />
              </Button>
            </a>
            <Button
              key={"GitHub"}
              className="h-8 w-8"
              variant="outline"
              size="icon"
            >
              <a href="https://github.com/lucasdoell">
                <GitHubIcon className="h-4 w-4" />
              </a>
            </Button>
            <Button
              key={"LinkedIn"}
              className="h-8 w-8"
              variant="outline"
              size="icon"
            >
              <a href="https://linkedin.com/in/lucasdoell">
                <LinkedInIcon className="h-4 w-4" />
              </a>
            </Button>
            <Button key={"X"} className="h-8 w-8" variant="outline" size="icon">
              <a href="https://twitter.com/lucasdoell">
                <XIcon className="h-4 w-4" />
              </a>
            </Button>
          </div>
        </div>

        <div class="h-28 w-28">
          <img
            src="/images/linkedin.jpg"
            class="rounded-xl"
            alt="An AI-generated photo of Lucas."
          />
        </div>
      </div>
      <Section>
        <h2 class="text-xl font-bold">About</h2>
        <p class="text-pretty font-mono text-sm text-muted-foreground">
          I'm currently working for Appstle Inc. as a software developer. I'm
          also learning new technologies and working on side projects in my free
          time.
        </p>
      </Section>
      <Section>
        <h2 class="text-xl font-bold">Work Experience</h2>
        <Card key={"Appstle"}>
          <CardHeader>
            <div class="flex items-center justify-between gap-x-2 text-base">
              <h3
                class="inline-flex items-center justify-center gap-x-1 font-semibold leading-none"
              >
                <a class="hover:underline" href="https://appstle.com">
                  Appstle Inc.
                </a>

                <span class="inline-flex gap-x-1">
                  <Badge variant="secondary" className="align-middle text-xs">
                    Remote
                  </Badge>
                </span>
              </h3>
              <div class="text-sm tabular-nums text-gray-500">
                February 2023 - December 2023
              </div>
            </div>

            <h4 class="font-mono text-sm leading-none">Software Developer</h4>
          </CardHeader>
          <CardContent className="mt-2 text-xs">
            At Appstle Inc., my role was multifaceted, focusing on developing
            new features for over 30,000 merchants and engaging in full-stack
            development using Java, TypeScript, and React. I refined our
            software by refactoring React components and managing a substantial
            codebase of over 500,000 lines. Additionally, I handled database
            management tasks with MySQL and DynamoDB, and created specialized
            internal tools for merchant-specific needs. My responsibilities also
            included implementing and optimizing AWS Step Functions to ensure
            robust and efficient task execution, underlining my comprehensive
            involvement in both front and backend development.
          </CardContent>
        </Card>
      </Section>
      <Section>
        <h2 class="text-xl font-bold">Education</h2>
        <Card key={"Cornell"}>
          <CardHeader>
            <div class="flex items-center justify-between gap-x-2 text-base">
              <h3 class="font-semibold leading-none">Cornell University</h3>
              <div class="text-sm tabular-nums text-gray-500">
                August 2021 - December 2022
              </div>
            </div>
          </CardHeader>
          <CardContent className="mt-2">
            Bachelor's in Computer Science
          </CardContent>
        </Card>
      </Section>
      <Section>
        <h2 class="text-xl font-bold">Skills</h2>
        <div class="flex flex-wrap gap-1">
          <Badge>JavaScript</Badge>
          <Badge>TypeScript</Badge>
          <Badge>Java</Badge>
          <Badge>React</Badge>
          <Badge>Next.js</Badge>
          <Badge>Node.js</Badge>
        </div>
      </Section>

      <Section className="print-force-new-page scroll-mb-16">
        <h2 class="text-xl font-bold">Projects</h2>
        <div
          class="-mx-3 lg:grid grid-cols-1 gap-3 print:grid-cols-3 print:gap-2 md:grid-cols-2 lg:grid-cols-3"
        >
          <ProjectCard
            title="Parsertime"
            description="A web app written to help collegiate Overwatch players track their statistics."
            tags={["Next.js", "Tailwind", "Prisma", "MySQL", "Vercel"]}
            link="https://github.com/lucasdoell/parsertime"
          />
          <ProjectCard
            title="Interpreter/Compiler"
            description="An interpreter and compiler for a toy language built in both Go and Rust."
            tags={["Go", "Rust", "Unit Testing"]}
            link="https://github.com/lucasdoell"
          />
          <ProjectCard
            title="OWL Bot"
            description="A Discord bot written in TypeScript that fetches OWL stats and schedules."
            tags={["Express", "Discord.js", "Web Scraping", "Docker", "Puppeteer"]}
            link="https://github.com/lucasdoell/owlbot"
          />
          <ProjectCard
            title="Sports Stats Web Scraper"
            description="Final project for CS 3110. Written primarily in OCaml with testing in OUnit2."
            tags={["OCaml", "OUnit2", "Web Scraping", "Python"]}
            link="https://github.com/lucasdoell/CS3110-scraping"
          />
          <ProjectCard
            title="Headless Shopify Store"
            description="A headless Shopify e-commerce store built with Next.js and Tailwind CSS."
            tags={["Next.js", "Tailwind", "Shopify"]}
            link="https://github.com/lucasdoell/shopify-nextjs"
          />
          <ProjectCard
            title="Roundest Pokemon"
            description="Built with Next.js, Tailwind, Prisma, tRPC, and MySQL."
            tags={["Next.js", "Tailwind", "Prisma", "MySQL", "tRPC", "Vercel"]}
            link="https://github.com/lucasdoell/shopify-nextjs"
          />
        </div>
      </Section>
    </section>
  </main>
</Layout>
